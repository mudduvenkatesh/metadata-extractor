<http://example.org/schema#CustomersShape>
    a <http://www.w3.org/ns/shacl#NodeShape> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "CUSTOMERSShape" ;
    <http://www.w3.org/ns/shacl#targetClass> <http://example.org/schema#Customers> ;

    <http://www.w3.org/ns/shacl#property> [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>      "CUSTOMER_ID" ;
          <http://www.w3.org/ns/shacl#path>      <http://example.org/schema#Customers_customerId> ;
          <http://www.w3.org/ns/shacl#datatype>  <http://www.w3.org/2001/XMLSchema#long> ;
          <http://www.w3.org/ns/shacl#NodeKind>  <http://www.w3.org/ns/shacl#Literal> ;
          <http://www.w3.org/ns/shacl#minCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#maxCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int>
      ] , [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>      "FIRST_NAME" ;
          <http://www.w3.org/ns/shacl#path>      <http://example.org/schema#Customers_firstName> ;
          <http://www.w3.org/ns/shacl#datatype>  <http://www.w3.org/2001/XMLSchema#string> ;
          <http://www.w3.org/ns/shacl#NodeKind>  <http://www.w3.org/ns/shacl#Literal> ;
          <http://www.w3.org/ns/shacl#maxLength> "100"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#minCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#maxCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int>
      ] , [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>      "LAST_NAME" ;
          <http://www.w3.org/ns/shacl#path>      <http://example.org/schema#Customers_lastName> ;
          <http://www.w3.org/ns/shacl#datatype>  <http://www.w3.org/2001/XMLSchema#string> ;
          <http://www.w3.org/ns/shacl#NodeKind>  <http://www.w3.org/ns/shacl#Literal> ;
          <http://www.w3.org/ns/shacl#maxLength> "100"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#minCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#maxCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int>
      ] , [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>      "EMAIL" ;
          <http://www.w3.org/ns/shacl#path>      <http://example.org/schema#Customers_email> ;
          <http://www.w3.org/ns/shacl#datatype>  <http://www.w3.org/2001/XMLSchema#string> ;
          <http://www.w3.org/ns/shacl#NodeKind>  <http://www.w3.org/ns/shacl#Literal> ;
          <http://www.w3.org/ns/shacl#maxLength> "255"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#minCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#maxCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int>
      ] , [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>      "PHONE" ;
          <http://www.w3.org/ns/shacl#path>      <http://example.org/schema#Customers_phone> ;
          <http://www.w3.org/ns/shacl#datatype>  <http://www.w3.org/2001/XMLSchema#string> ;
          <http://www.w3.org/ns/shacl#NodeKind>  <http://www.w3.org/ns/shacl#Literal> ;
          <http://www.w3.org/ns/shacl#maxLength> "20"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#maxCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int>
          # no sh:minCount — nullable column
      ] , [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>      "CREATED_AT" ;
          <http://www.w3.org/ns/shacl#path>      <http://example.org/schema#Customers_createdAt> ;
          <http://www.w3.org/ns/shacl#datatype>  <http://www.w3.org/2001/XMLSchema#dateTime> ;
          <http://www.w3.org/ns/shacl#NodeKind>  <http://www.w3.org/ns/shacl#Literal> ;
          <http://www.w3.org/ns/shacl#minCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int> ;
          <http://www.w3.org/ns/shacl#maxCount>  "1"^^<http://www.w3.org/2001/XMLSchema#int>
      ] ;

    # UNIQUE constraints → sh:sparql nodes
    <http://www.w3.org/ns/shacl#sparql> [
          a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
          <http://www.w3.org/ns/shacl#message> "UNIQUE constraint violated: PRIMARY_KEY_6 (CUSTOMER_ID)" ;
          <http://www.w3.org/2000/01/rdf-schema#comment> "UNIQUE on columns: CUSTOMER_ID"
      ] , [
          a <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
          <http://www.w3.org/ns/shacl#message> "UNIQUE constraint violated: UQ_CUSTOMERS_EMAIL_INDEX_6 (EMAIL)" ;
          <http://www.w3.org/2000/01/rdf-schema#comment> "UNIQUE on columns: EMAIL"
      ] .


<http://example.org/schema#ProductsShape>
    a <http://www.w3.org/ns/shacl#NodeShape> ;
    <http://www.w3.org/2000/01/rdf-schema#label> "PRODUCTSShape" ;
    <http://www.w3.org/ns/shacl#targetClass> <http://example.org/schema#Products> ;

    <http://www.w3.org/ns/shacl#property> [
          a <http://www.w3.org/ns/shacl#PropertyShape> ;
          <http://www.w3.org/ns/shacl#name>     "PRODUCT_ID" ;
          <http://www.w3.org/ns/shacl#path>     <http://example.org/schema#Products_productId> ;
          <http://www.w3.org/ns/shacl#datatype>